/*
BeamLabStudio Qt Style Kit
Use:
QFile f(":/styles/beamlabstudio.qss");
f.open(QFile::ReadOnly);
qApp->setStyleSheet(QString::fromUtf8(f.readAll()));
*/

* {
    font-family: "Inter", "Segoe UI", "Noto Sans", "DejaVu Sans", Arial, sans-serif;
    color: #EAF2FF;
    font-size: 14px;
}

QMainWindow, QWidget {
    background: #0B111A;
}

QFrame#TopBar {
    background: #111827;
    border-bottom: 1px solid #2A3A55;
}

QFrame#Panel,
QGroupBox {
    background: #111827;
    border: 1px solid #2A3A55;
    border-radius: 14px;
    padding: 10px;
}

QGroupBox::title {
    color: #AAB8CF;
    subcontrol-origin: margin;
    left: 14px;
    padding: 0 6px;
}

QLabel#AppTitle {
    font-size: 26px;
    font-weight: 750;
    color: #EAF2FF;
}

QLabel#Subtitle,
QLabel#Muted {
    color: #AAB8CF;
}

QPushButton {
    background: #1E2A3F;
    border: 1px solid #3B4D6B;
    border-radius: 10px;
    padding: 8px 14px;
    color: #EAF2FF;
    font-weight: 600;
}

QPushButton:hover {
    background: #243653;
    border: 1px solid #60A5FA;
}

QPushButton:pressed {
    background: #2563EB;
}

QPushButton#PrimaryButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #2563EB, stop:1 #67E8F9);
    color: #06111F;
    border: 0px;
    font-weight: 800;
}

QPushButton#PrimaryButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #60A5FA, stop:1 #67E8F9);
}

QPushButton#DangerButton {
    background: #32131B;
    border: 1px solid #FB7185;
    color: #FB7185;
}

QPushButton:disabled {
    background: #151C28;
    border: 1px solid #263145;
    color: #607089;
}

QTabWidget::pane {
    border: 1px solid #2A3A55;
    border-radius: 12px;
    top: -1px;
    background: #111827;
}

QTabBar::tab {
    background: #162033;
    color: #AAB8CF;
    padding: 9px 16px;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    margin-right: 3px;
}

QTabBar::tab:selected {
    background: #2563EB;
    color: white;
}

QTabBar::tab:hover:!selected {
    background: #1E2A3F;
    color: #EAF2FF;
}

QLineEdit, QTextEdit, QPlainTextEdit, QComboBox, QSpinBox, QDoubleSpinBox {
    background: #0E1624;
    border: 1px solid #2A3A55;
    border-radius: 9px;
    padding: 7px 10px;
    selection-background-color: #2563EB;
}

QComboBox::drop-down {
    border: 0px;
    width: 28px;
}

QSlider::groove:horizontal {
    height: 6px;
    background: #243146;
    border-radius: 3px;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #2563EB, stop:1 #67E8F9);
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 18px;
    height: 18px;
    margin: -7px 0;
    border-radius: 9px;
    background: #67E8F9;
    border: 2px solid #DDFBFF;
}

QProgressBar {
    background: #0E1624;
    border: 1px solid #2A3A55;
    border-radius: 8px;
    text-align: center;
    color: #EAF2FF;
}

QProgressBar::chunk {
    border-radius: 7px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #2563EB, stop:1 #67E8F9);
}

QCheckBox {
    spacing: 8px;
    color: #EAF2FF;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: 1px solid #3B4D6B;
    background: #0E1624;
}

QCheckBox::indicator:checked {
    background: #67E8F9;
    border: 1px solid #67E8F9;
}

QTableView {
    background: #0E1624;
    gridline-color: #2A3A55;
    alternate-background-color: #101A2A;
    border: 1px solid #2A3A55;
    border-radius: 10px;
}

QHeaderView::section {
    background: #1E2A3F;
    color: #EAF2FF;
    padding: 7px;
    border: 0px;
    border-right: 1px solid #2A3A55;
}

QScrollBar:vertical {
    background: #111827;
    width: 12px;
}

QScrollBar::handle:vertical {
    background: #3B4D6B;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QToolTip {
    background: #0E1624;
    color: #EAF2FF;
    border: 1px solid #3B4D6B;
    border-radius: 8px;
    padding: 8px;
}

/* === BeamLabStudio layout polish: docks, top bar, welcome === */

QWidget#TopBar,
QFrame#TopBar {
    background: #0B111A;
    border: 0px;
    border-bottom: 1px solid #2A3A55;
}

QWidget#TopBar QLabel,
QFrame#TopBar QLabel {
    color: #EAF2FF;
}

QWidget#TopBar QPushButton,
QFrame#TopBar QPushButton {
    min-height: 30px;
    max-height: 34px;
    padding: 6px 10px;
    margin: 0px 2px;
    border-radius: 9px;
    background: #111827;
    border: 1px solid #2A3A55;
}

QWidget#TopBar QPushButton:hover,
QFrame#TopBar QPushButton:hover {
    background: #1E2A3F;
    border: 1px solid #60A5FA;
}

QMenuBar {
    background: #0B111A;
    color: #EAF2FF;
    border: 0px;
    padding: 4px 8px;
}

QMenuBar::item {
    background: transparent;
    color: #AAB8CF;
    padding: 6px 10px;
    border-radius: 7px;
}

QMenuBar::item:selected {
    background: #1E2A3F;
    color: #EAF2FF;
}

QMenu {
    background: #111827;
    color: #EAF2FF;
    border: 1px solid #2A3A55;
    border-radius: 10px;
    padding: 6px;
}

QMenu::item {
    padding: 7px 28px 7px 12px;
    border-radius: 7px;
}

QMenu::item:selected {
    background: #2563EB;
    color: white;
}

QDockWidget {
    color: #EAF2FF;
    background: #0B111A;
}

QDockWidget::title {
    background: #111827;
    color: #EAF2FF;
    padding: 8px 10px;
    border: 1px solid #2A3A55;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

QDockWidget QWidget {
    background: #111827;
}

QSplitter::handle {
    background: #2A3A55;
}

QSplitter::handle:hover {
    background: #60A5FA;
}

QWidget#WelcomePage {
    background: #0B111A;
}

QLabel#WelcomeLogo {
    min-width: 820px;
    min-height: 220px;
}

QLabel#CreatorAttribution {
    color: #AAB8CF;
    font-size: 15px;
    padding-top: 6px;
}

QLabel#WelcomeDropzone {
    min-width: 720px;
    min-height: 300px;
}


/* === Dock scrollability and panel usability === */

QDockWidget#CombinedControlsDock {
    background: #0B111A;
    border: 1px solid #24324A;
}

QDockWidget#CombinedControlsDock::title {
    padding: 9px 12px;
    background: #111827;
    color: #EAF2FF;
    border-bottom: 1px solid #2A3A55;
}

QScrollArea#CombinedControlsDock_scroll,
QScrollArea#CombinedControlsDock_scroll QWidget {
    background: #111827;
}

QScrollBar:vertical {
    background: #0B111A;
    width: 13px;
    margin: 2px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: #35547A;
    min-height: 34px;
    border-radius: 6px;
}

QScrollBar::handle:vertical:hover {
    background: #60A5FA;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

QDockWidget QPushButton {
    min-height: 34px;
}

QDockWidget QComboBox,
QDockWidget QSpinBox,
QDockWidget QDoubleSpinBox {
    min-height: 30px;
}

