QColor seriesColor(const QString& title)
{
    if (title.contains("area", Qt::CaseInsensitive)) {
        return QColor(255, 190, 120);
    }

    if (title.contains("Points", Qt::CaseInsensitive)) {
        return QColor(132, 232, 172);
    }

    return curve();
