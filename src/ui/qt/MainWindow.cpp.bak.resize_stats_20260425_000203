QString MainWindow::readTextFile(const QString& path) const
{
    QFile file(path);

    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
        return {};
    }

    QTextStream stream(&file);
    return stream.readAll();
}

QString MainWindow::extractJsonString(const QString& text,
                                      const QString& key) const
{
    const QString pattern =
        QStringLiteral("\"%1\"\\s*:\\s*\"([^\"]*)\"").arg(QRegularExpression::escape(key));

    const QRegularExpression regex(pattern);
    const auto match = regex.match(text);

    if (!match.hasMatch()) {
        return {};
    }

    return match.captured(1);
}

QString MainWindow::extractJsonNumber(const QString& text,
                                      const QString& key) const
{
    const QString pattern =
        QStringLiteral("\"%1\"\\s*:\\s*([-+0-9.eE]+)").arg(QRegularExpression::escape(key));

    const QRegularExpression regex(pattern);
    const auto match = regex.match(text);

    if (!match.hasMatch()) {
        return {};
    }

    return match.captured(1);
}

QString MainWindow::resolvePath(const QString& raw_path,
                                const QString& manifest_path) const
{
    if (raw_path.isEmpty()) {
        return {};
    }

    const QFileInfo raw_info(raw_path);

    if (raw_info.isAbsolute() && raw_info.exists()) {
        return raw_info.absoluteFilePath();
    }

    if (raw_info.exists()) {
        return raw_info.absoluteFilePath();
    }

    QFileInfo manifest_info(manifest_path);
    QDir dir = manifest_info.dir();

    for (int depth = 0; depth < 10; ++depth) {
        const QString candidate = dir.absoluteFilePath(raw_path);

        if (QFileInfo(candidate).exists()) {
            return QFileInfo(candidate).absoluteFilePath();
        }

        if (!dir.cdUp()) {
            break;
        }
    }

    return raw_path;
}

QString MainWindow::makeDashboardText(const QString& manifest_text,
                                      const QString& trajectories_csv,
                                      const QString& focal_slice_csv,
                                      const QString& envelope_csv,
                                      const QString& caustic_obj,
                                      const QString& lens_obj) const
{
    QString text;

    text += "BeamLabStudio run dashboard\n";
    text += "===========================\n\n";

    text += "Configuration\n";
    text += "-------------\n";
    text += "Axis mode:       " + extractJsonString(manifest_text, "axis_mode") + "\n";
    text += "Reference mode:  " + extractJsonString(manifest_text, "reference_mode") + "\n";
    text += "Binning mode:    " + extractJsonString(manifest_text, "binning_mode") + "\n";
    text += "Axial bins:      " + extractJsonNumber(manifest_text, "axial_bin_count") + "\n";
    text += "Window:          " + extractJsonNumber(manifest_text, "half_window_frames") + "\n\n";

    text += "Visualization rows\n";
    text += "------------------\n";
    text += "Trajectories preview: " + extractJsonNumber(manifest_text, "trajectories_preview") + "\n";
    text += "Focal slice points:   " + extractJsonNumber(manifest_text, "focal_slice_points") + "\n";
    text += "Envelope proxy rings: " + extractJsonNumber(manifest_text, "envelope_rings") + "\n\n";

    text += "Loaded files\n";
    text += "------------\n";
    text += "Trajectories CSV:\n  " + trajectories_csv + "\n  status: " + fileStatus(trajectories_csv) + "\n\n";
    text += "Focal slice CSV:\n  " + focal_slice_csv + "\n  status: " + fileStatus(focal_slice_csv) + "\n\n";
    text += "Focal envelope proxy rings CSV:\n  " + envelope_csv + "\n  status: " + fileStatus(envelope_csv) + "\n\n";

    if (fileStatus(trajectories_csv) == "missing" ||
        fileStatus(focal_slice_csv) == "missing" ||
        fileStatus(envelope_csv) == "missing") {
        text += "WARNING\n";
        text += "-------\n";
        text += "At least one visualization CSV is missing from the path resolved by the UI.\n";
        text += "The manifest is an internal analysis contract; check the run output paths on disk.\n\n";
    }
    text += "Focal envelope proxy preview OBJ:\n  " +
        caustic_obj +
        "\n  status: " +
        fileStatus(caustic_obj) +
        "\n\n";
    text += "Effective lens body preview OBJ:\n  " + lens_obj + "\n  status: " + fileStatus(lens_obj) + "\n\n";

    text += "Notes\n";
    text += "-----\n";
    text += "This UI is reading lightweight preview files, not the full simulation dataset.\n";
    text += "Envelope proxy: boundary surface reconstructed from transverse beam slices. It is not the physical beamline tube.\n";
    text += "Full beam envelope preview can be built from loaded trajectory samples; future engine output can replace it with a full-resolution layer.\n";
    text += "Physical beamline geometry is handled as a separate imported OBJ layer.\n";
    text += "The effective lens is a focal-aperture proxy, not a unique inverse reconstruction of the magnet.\n";

    return text;
}

void MainWindow::saveSettings()
{
    QSettings settings("BeamLab", "BeamLabStudio");
    settings.setValue("window/geometry", saveGeometry());
    settings.setValue("window/state", saveState());
    settings.setValue("last_open_dir", last_open_dir_);

    if (beam_display_mode_ != nullptr) {
        settings.setValue("3d/beam_display_mode", beam_display_mode_->currentIndex());
    }

    if (show_axes_check_ != nullptr) {
        settings.setValue("3d/show_axes", show_axes_check_->isChecked());
    }

    if (show_measure_guides_check_ != nullptr) {
        settings.setValue("3d/show_measure_guides", show_measure_guides_check_->isChecked());
    }
}

void MainWindow::restoreSettings()
{
    QSettings settings("BeamLab", "BeamLabStudio");

    const QByteArray geometry = settings.value("window/geometry").toByteArray();

    if (!geometry.isEmpty()) {
        restoreGeometry(geometry);
    }

    const QByteArray state = settings.value("window/state").toByteArray();

    if (!state.isEmpty()) {
        restoreState(state);
    }

    last_open_dir_ = settings.value("last_open_dir", QString()).toString();

    if (beam_display_mode_ != nullptr) {
        const int saved_mode = settings.value("3d/beam_display_mode", 1).toInt();
        const int clamped_mode =
            std::clamp(saved_mode, 0, std::max(0, beam_display_mode_->count() - 1));
        beam_display_mode_->setCurrentIndex(clamped_mode);
        updateCombinedDisplayMode();
    }

    const bool show_axes = settings.value("3d/show_axes", true).toBool();
    const bool show_guides = settings.value("3d/show_measure_guides", true).toBool();

    if (show_axes_check_ != nullptr) {
        const QSignalBlocker blocker(show_axes_check_);
        show_axes_check_->setChecked(show_axes);
    }

    if (show_measure_guides_check_ != nullptr) {
        const QSignalBlocker blocker(show_measure_guides_check_);
        show_measure_guides_check_->setChecked(show_guides);
    }

    if (combined_scene_viewer_ != nullptr) {
        combined_scene_viewer_->setAxesVisible(show_axes);
        combined_scene_viewer_->setMeasureGuidesVisible(show_guides);
    }

    for (QCheckBox* checkbox : obj_axes_checks_) {
        if (checkbox != nullptr) {
            const QSignalBlocker blocker(checkbox);
            checkbox->setChecked(show_axes);
        }
    }

    for (QCheckBox* checkbox : obj_measure_guides_checks_) {
        if (checkbox != nullptr) {
            const QSignalBlocker blocker(checkbox);
            checkbox->setChecked(show_guides);
        }
    }

    for (ObjViewerWidget* viewer : {
             trajectories_obj_viewer_,
             caustic_obj_viewer_,
             lens_obj_viewer_
         }) {
        if (viewer != nullptr) {
            viewer->setAxesVisible(show_axes);
            viewer->setMeasureGuidesVisible(show_guides);
        }
    }
}

void MainWindow::updateRecentMenu()
{
    if (recent_menu_ == nullptr) {
        return;
    }

    recent_menu_->clear();

    QSettings settings("BeamLab", "BeamLabStudio");
    const QStringList recent_runs = settings.value("recent_runs").toStringList();

    if (recent_runs.isEmpty()) {
        QAction* empty_action = recent_menu_->addAction("No recent runs");
        empty_action->setEnabled(false);
        return;
    }

    for (const QString& path : recent_runs) {
        QAction* action = recent_menu_->addAction(QFileInfo(path).fileName());
        action->setToolTip(path);
        connect(action, &QAction::triggered, this, [this, path]() {
            loadManifest(path);
        });
    }
}

void MainWindow::addToRecentRuns(const QString& manifest_path)
{
    const QString absolute_path = QFileInfo(manifest_path).absoluteFilePath();

    if (absolute_path.isEmpty()) {
        return;
    }

    QSettings settings("BeamLab", "BeamLabStudio");
    QStringList recent_runs = settings.value("recent_runs").toStringList();
    recent_runs.removeAll(absolute_path);
    recent_runs.prepend(absolute_path);

    while (recent_runs.size() > 8) {
        recent_runs.removeLast();
    }

    settings.setValue("recent_runs", recent_runs);
    updateRecentMenu();
}

