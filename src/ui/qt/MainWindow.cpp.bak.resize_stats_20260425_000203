void MainWindow::adjustCombinedLayerIndicesAfterRemoval(const int removed_layer)
{
    const auto adjust = [removed_layer](int& layer) {
        if (layer == removed_layer) {
            layer = -1;
        } else if (layer > removed_layer) {
            --layer;
        }
    };

    adjust(combined_trajectory_layer_);
    adjust(combined_caustic_layer_);
    adjust(combined_lens_layer_);
    adjust(combined_full_envelope_layer_);
    adjust(combined_beamline_layer_);
}

bool MainWindow::buildFullEnvelopePreviewObj(const QString& trajectories_csv,
                                             const QString& output_obj,
                                             QString* error) const
{
    QFile file(trajectories_csv);

    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
        if (error != nullptr) {
            *error = "Could not open trajectories CSV:\n" + trajectories_csv;
        }
        return false;
    }

    struct Sample {
        double x{0.0};
        double y{0.0};
        double z{0.0};
    };

    std::vector<Sample> samples;
    samples.reserve(60000);

    QTextStream stream(&file);
    QStringList header;
    int x_col = -1;
    int y_col = -1;
    int z_col = -1;

    while (!stream.atEnd()) {
        const QString line = stream.readLine();

        if (line.trimmed().isEmpty() || line.startsWith("#")) {
            continue;
        }

        if (header.isEmpty()) {
            header = splitCsvLine(line);
            x_col = columnIndex(header, "x_m");
            y_col = columnIndex(header, "y_m");
            z_col = columnIndex(header, "z_m");
            continue;
        }

        const QStringList cols = splitCsvLine(line);

        if (x_col < 0 || y_col < 0 || z_col < 0 ||
            x_col >= cols.size() || y_col >= cols.size() || z_col >= cols.size()) {
            continue;
        }

        bool ok_x = false;
        bool ok_y = false;
        bool ok_z = false;
        const double x = cols[x_col].toDouble(&ok_x);
        const double y = cols[y_col].toDouble(&ok_y);
        const double z = cols[z_col].toDouble(&ok_z);

        if (ok_x && ok_y && ok_z &&
            std::isfinite(x) && std::isfinite(y) && std::isfinite(z)) {
            samples.push_back({x, y, z});
        }
    }

    if (samples.size() < 16) {
        if (error != nullptr) {
            *error = "Not enough trajectory samples to build a full envelope preview.";
        }
        return false;
    }

    std::array<double, 3> min_coord{
        std::numeric_limits<double>::infinity(),
        std::numeric_limits<double>::infinity(),
        std::numeric_limits<double>::infinity()
    };
    std::array<double, 3> max_coord{
        -std::numeric_limits<double>::infinity(),
        -std::numeric_limits<double>::infinity(),
        -std::numeric_limits<double>::infinity()
    };

    const auto coord = [](const Sample& sample, const int axis) {
        if (axis == 0) {
            return sample.x;
        }

        if (axis == 1) {
            return sample.y;
        }

        return sample.z;
    };

    for (const auto& sample : samples) {
        min_coord[0] = std::min(min_coord[0], sample.x);
        min_coord[1] = std::min(min_coord[1], sample.y);
        min_coord[2] = std::min(min_coord[2], sample.z);

        max_coord[0] = std::max(max_coord[0], sample.x);
        max_coord[1] = std::max(max_coord[1], sample.y);
        max_coord[2] = std::max(max_coord[2], sample.z);
    }

    const std::array<double, 3> span{
        max_coord[0] - min_coord[0],
        max_coord[1] - min_coord[1],
        max_coord[2] - min_coord[2]
    };

    int longitudinal_axis = 0;

    if (span[1] > span[static_cast<std::size_t>(longitudinal_axis)]) {
        longitudinal_axis = 1;
    }

    if (span[2] > span[static_cast<std::size_t>(longitudinal_axis)]) {
        longitudinal_axis = 2;
    }

    std::array<int, 2> transverse_axes{0, 1};
    int transverse_slot = 0;

    for (int axis = 0; axis < 3; ++axis) {
        if (axis != longitudinal_axis) {
            transverse_axes[static_cast<std::size_t>(transverse_slot)] = axis;
            ++transverse_slot;
        }
    }

    const double longitudinal_min = min_coord[static_cast<std::size_t>(longitudinal_axis)];
    const double longitudinal_span = span[static_cast<std::size_t>(longitudinal_axis)];

    if (longitudinal_span <= 1.0e-15) {
        if (error != nullptr) {
            *error = "Trajectory preview has no usable longitudinal range for a full envelope preview.";
        }
        return false;
    }

    constexpr int angle_count = 48;
    constexpr double pi = 3.141592653589793238462643383279502884;
    const int bin_count = std::clamp(
        static_cast<int>(samples.size() / 500),
        24,
        72
    );

    struct Bin {
        int count{0};
        double sum_longitudinal{0.0};
        double sum_a{0.0};
        double sum_b{0.0};
        double center_longitudinal{0.0};
        double center_a{0.0};
        double center_b{0.0};
        double max_radius{0.0};
        double fallback_radius{0.0};
        std::vector<std::vector<double>> angular_radii{};
        std::vector<double> angular_radius{};
    };

    std::vector<Bin> bins(static_cast<std::size_t>(bin_count));

    for (auto& bin : bins) {
        bin.angular_radii.resize(angle_count);
        bin.angular_radius.assign(angle_count, 0.0);
    }

    const auto binIndexForLongitudinal = [&](const double longitudinal) {
        const double t =
            std::clamp((longitudinal - longitudinal_min) / longitudinal_span, 0.0, 1.0);
        return std::clamp(
            static_cast<int>(std::floor(t * static_cast<double>(bin_count - 1))),
            0,
            bin_count - 1
        );
    };

    for (const auto& sample : samples) {
        const double longitudinal = coord(sample, longitudinal_axis);
        const double a = coord(sample, transverse_axes[0]);
        const double b = coord(sample, transverse_axes[1]);

        Bin& bin =
            bins[static_cast<std::size_t>(binIndexForLongitudinal(longitudinal))];
        ++bin.count;
        bin.sum_longitudinal += longitudinal;
        bin.sum_a += a;
        bin.sum_b += b;
    }

    for (auto& bin : bins) {
        if (bin.count <= 0) {
            continue;
        }

        const double inv_count = 1.0 / static_cast<double>(bin.count);
        bin.center_longitudinal = bin.sum_longitudinal * inv_count;
        bin.center_a = bin.sum_a * inv_count;
        bin.center_b = bin.sum_b * inv_count;
    }

    for (const auto& sample : samples) {
        const double longitudinal = coord(sample, longitudinal_axis);
        const double a = coord(sample, transverse_axes[0]);
        const double b = coord(sample, transverse_axes[1]);

        Bin& bin =
            bins[static_cast<std::size_t>(binIndexForLongitudinal(longitudinal))];

        if (bin.count <= 0) {
            continue;
        }

        const double da = a - bin.center_a;
        const double db = b - bin.center_b;
        const double radius = std::hypot(da, db);
        double angle = std::atan2(db, da);

        if (angle < 0.0) {
            angle += 2.0 * pi;
        }

        const int angle_index = std::clamp(
            static_cast<int>(std::floor(angle * static_cast<double>(angle_count) / (2.0 * pi))),
            0,
            angle_count - 1
        );

        bin.angular_radii[static_cast<std::size_t>(angle_index)].push_back(radius);
        bin.max_radius = std::max(bin.max_radius, radius);
    }

    const auto quantileRadius = [](std::vector<double>& values, const double q) {
        if (values.empty()) {
            return 0.0;
        }

        std::sort(values.begin(), values.end());
        const std::size_t index =
            std::min<std::size_t>(
                values.size() - 1,
                static_cast<std::size_t>(
                    std::floor(q * static_cast<double>(values.size() - 1))
                )
            );
        return values[index];
    };

    for (auto& bin : bins) {
        if (bin.count <= 0) {
            continue;
        }

        std::vector<double> all_radii;

        for (const auto& sector : bin.angular_radii) {
            all_radii.insert(all_radii.end(), sector.begin(), sector.end());
        }

        bin.fallback_radius = quantileRadius(all_radii, 0.90);

        if (bin.fallback_radius <= 0.0) {
            bin.fallback_radius = bin.max_radius;
        }

        for (int angle_index = 0; angle_index < angle_count; ++angle_index) {
            auto& sector = bin.angular_radii[static_cast<std::size_t>(angle_index)];
            double radius = quantileRadius(sector, 0.90);

            if (radius <= 0.0) {
                radius = bin.fallback_radius;
            }

            bin.angular_radius[static_cast<std::size_t>(angle_index)] = radius;
        }

        for (int smooth_pass = 0; smooth_pass < 2; ++smooth_pass) {
            std::vector<double> smoothed = bin.angular_radius;

            for (int angle_index = 0; angle_index < angle_count; ++angle_index) {
                const int previous = (angle_index + angle_count - 1) % angle_count;
                const int next = (angle_index + 1) % angle_count;
                smoothed[static_cast<std::size_t>(angle_index)] =
                    0.25 * bin.angular_radius[static_cast<std::size_t>(previous)] +
                    0.50 * bin.angular_radius[static_cast<std::size_t>(angle_index)] +
                    0.25 * bin.angular_radius[static_cast<std::size_t>(next)];
            }

            bin.angular_radius = std::move(smoothed);
        }
    }

    std::vector<int> valid_bins;

    for (int i = 0; i < bin_count; ++i) {
        const auto& bin = bins[static_cast<std::size_t>(i)];

        if (bin.count >= 6 && bin.fallback_radius > 0.0) {
            valid_bins.push_back(i);
        }
    }

    if (valid_bins.size() < 2) {
        if (error != nullptr) {
            *error = "The trajectory preview did not produce enough valid envelope slices.";
        }
        return false;
    }

    QFileInfo output_info(output_obj);

    if (!QDir().mkpath(output_info.absolutePath())) {
        if (error != nullptr) {
            *error = "Could not create geometry directory:\n" + output_info.absolutePath();
        }
        return false;
    }

    std::ofstream output(output_obj.toStdString());

    if (!output) {
        if (error != nullptr) {
            *error = "Could not write OBJ:\n" + output_obj;
        }
        return false;
    }

    output << "# BeamLabStudio full beam envelope preview\n";
    output << "# Generated from trajectories_preview.csv; use as a visual proxy only.\n";
    output << "# longitudinal_axis: " << (longitudinal_axis == 0 ? "x" : longitudinal_axis == 1 ? "y" : "z") << "\n";
    output << "# vertices: x_m y_m z_m\n";

    const auto makeWorldPoint = [&](const double longitudinal,
                                    const double a,
                                    const double b) {
        std::array<double, 3> values{0.0, 0.0, 0.0};
        values[static_cast<std::size_t>(longitudinal_axis)] = longitudinal;
        values[static_cast<std::size_t>(transverse_axes[0])] = a;
        values[static_cast<std::size_t>(transverse_axes[1])] = b;
        return Sample{values[0], values[1], values[2]};
    };

    for (const int bin_index : valid_bins) {
        const Bin& bin = bins[static_cast<std::size_t>(bin_index)];

        for (int angle_index = 0; angle_index < angle_count; ++angle_index) {
            const double angle =
                2.0 * pi * static_cast<double>(angle_index) /
                static_cast<double>(angle_count);
            double radius = bin.angular_radius[static_cast<std::size_t>(angle_index)];

            if (radius <= 0.0) {
                radius = bin.fallback_radius;
            }

            const Sample world =
                makeWorldPoint(
                    bin.center_longitudinal,
                    bin.center_a + radius * std::cos(angle),
                    bin.center_b + radius * std::sin(angle)
                );

            output << "v "
                   << world.x << ' '
                   << world.y << ' '
                   << world.z << '\n';
        }
    }

    for (std::size_t ring = 1; ring < valid_bins.size(); ++ring) {
        const int previous_base =
            static_cast<int>((ring - 1) * static_cast<std::size_t>(angle_count)) + 1;
        const int current_base =
            static_cast<int>(ring * static_cast<std::size_t>(angle_count)) + 1;

        for (int angle_index = 0; angle_index < angle_count; ++angle_index) {
            const int next = (angle_index + 1) % angle_count;
            output << "f "
                   << previous_base + angle_index << ' '
                   << previous_base + next << ' '
                   << current_base + next << ' '
                   << current_base + angle_index << '\n';
        }
    }

    return true;
}

void MainWindow::buildFullEnvelopePreview()
{
    if (!ensureRunLoaded()) {
        return;
    }

    if (current_trajectories_csv_.isEmpty() ||
        !QFileInfo::exists(current_trajectories_csv_)) {
        QMessageBox::warning(
            this,
            "Full beam envelope",
            "The current run does not have a trajectories_preview.csv file."
        );
        return;
    }

    const QString output_obj =
        QDir(current_run_dir_).filePath("geometry/full_beam_envelope_preview.obj");

    QString error;
    QApplication::setOverrideCursor(Qt::WaitCursor);
    const bool ok = buildFullEnvelopePreviewObj(
        current_trajectories_csv_,
        output_obj,
        &error
    );
    QApplication::restoreOverrideCursor();

    if (!ok) {
        QMessageBox::warning(this, "Full beam envelope", error);
        return;
    }

    if (combined_full_envelope_layer_ >= 0 &&
        combined_scene_viewer_->removeLayer(combined_full_envelope_layer_)) {
        adjustCombinedLayerIndicesAfterRemoval(combined_full_envelope_layer_);
    }

    combined_full_envelope_layer_ = combined_scene_viewer_->addObjLayer(
        "Full beam envelope",
        output_obj,
        QColor(180, 140, 255)
    );

    if (combined_full_envelope_layer_ < 0) {
        QMessageBox::warning(
            this,
            "Full beam envelope",
            "The full envelope OBJ was written but could not be loaded."
        );
        return;
    }

    current_full_envelope_obj_ = output_obj;
    updateLayerSwatch(full_envelope_color_swatch_, QColor(180, 140, 255));
    combined_scene_viewer_->setLayerOpacity(combined_full_envelope_layer_, 0.25);
    combined_scene_viewer_->setLayerLineWidth(combined_full_envelope_layer_, 0.9);

    QFile manifest_file(current_manifest_path_);

    if (manifest_file.open(QIODevice::ReadOnly | QIODevice::Text)) {
        QJsonParseError parse_error{};
        QJsonDocument document =
            QJsonDocument::fromJson(manifest_file.readAll(), &parse_error);
        manifest_file.close();

        if (parse_error.error == QJsonParseError::NoError && document.isObject()) {
            QJsonObject root = document.object();
            QJsonObject files = root.value("files").toObject();
            files.insert(
                "full_beam_envelope_preview_obj",
                manifestFriendlyPath(output_obj)
            );
            root.insert("files", files);

            QJsonObject layer_semantics = root.value("layer_semantics").toObject();
            QJsonObject full_envelope = layer_semantics.value("full_beam_envelope_obj").toObject();
            full_envelope.insert("display_name", "Full beam envelope");
            full_envelope.insert("status", "available_preview");
            full_envelope.insert("scope", "preview_axial_range");
            full_envelope.insert(
                "description",
                "Preview envelope reconstructed from the loaded trajectory sample."
            );
            layer_semantics.insert("full_beam_envelope_obj", full_envelope);
            root.insert("layer_semantics", layer_semantics);

            if (manifest_file.open(QIODevice::WriteOnly | QIODevice::Text | QIODevice::Truncate)) {
                manifest_file.write(QJsonDocument(root).toJson(QJsonDocument::Indented));
                manifest_file.close();
            }
        }
    }

    {
        const QSignalBlocker blocker(combined_full_envelope_check_);
        combined_full_envelope_check_->setEnabled(true);
        combined_full_envelope_check_->setChecked(true);
    }

    if (beam_display_mode_ != nullptr) {
        beam_display_mode_->setCurrentIndex(2);
    }

    updateCombinedDisplayMode();
    status_label_->setText("Full beam envelope preview built: " + output_obj);
}

void MainWindow::importPhysicalBeamlineGeometry()
{
    const QString initial_dir =
        current_run_dir_.isEmpty()
            ? projectRootDir().absolutePath()
            : current_run_dir_;

    const QString path = QFileDialog::getOpenFileName(
        this,
        "Import physical beamline OBJ",
        initial_dir,
        "OBJ geometry (*.obj);;All files (*)"
    );

    if (path.isEmpty()) {
        return;
    }

    if (combined_beamline_layer_ >= 0 &&
        combined_scene_viewer_->removeLayer(combined_beamline_layer_)) {
        adjustCombinedLayerIndicesAfterRemoval(combined_beamline_layer_);
    }

    combined_beamline_layer_ = combined_scene_viewer_->addObjLayer(
        "Physical beamline geometry",
        path,
        QColor(205, 214, 226)
    );

    if (combined_beamline_layer_ < 0) {
        QMessageBox::warning(
            this,
            "Physical beamline geometry",
            "Could not load the selected OBJ file."
        );
        return;
    }

    current_beamline_obj_ = path;
    updateLayerSwatch(beamline_color_swatch_, QColor(205, 214, 226));
    combined_scene_viewer_->setLayerOpacity(combined_beamline_layer_, 0.55);
    combined_scene_viewer_->setLayerLineWidth(combined_beamline_layer_, 1.0);

    {
        const QSignalBlocker blocker(combined_beamline_check_);
        combined_beamline_check_->setEnabled(true);
        combined_beamline_check_->setChecked(true);
    }

    clear_beamline_button_->setEnabled(true);

    if (beam_display_mode_ != nullptr) {
        beam_display_mode_->setCurrentIndex(2);
    }

    updateCombinedDisplayMode();
    status_label_->setText("Imported physical beamline geometry: " + path);
}

void MainWindow::clearPhysicalBeamlineGeometry()
{
    if (combined_beamline_layer_ >= 0 &&
        combined_scene_viewer_->removeLayer(combined_beamline_layer_)) {
        adjustCombinedLayerIndicesAfterRemoval(combined_beamline_layer_);
    }

    combined_beamline_layer_ = -1;
    current_beamline_obj_.clear();

    {
        const QSignalBlocker blocker(combined_beamline_check_);
        combined_beamline_check_->setEnabled(false);
        combined_beamline_check_->setChecked(false);
    }

    clear_beamline_button_->setEnabled(false);
    updateCombinedDisplayMode();
    status_label_->setText("Physical beamline geometry layer cleared");
}

void MainWindow::loadTablePreview(const QString& path,
                                  QTableWidget* table,
                                  const int max_rows)
{
    table->clear();

    QFile file(path);
    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
        table->setRowCount(0);
        table->setColumnCount(1);
        table->setHorizontalHeaderLabels({"Could not open: " + path});
        return;
    }

    QTextStream stream(&file);

    QStringList header;
    std::vector<QStringList> rows;

    while (!stream.atEnd()) {
        const auto line = stream.readLine();

        if (line.trimmed().isEmpty() || line.startsWith("#")) {
            continue;
        }

        if (header.isEmpty()) {
            header = splitCsvLine(line);
            continue;
        }

        rows.push_back(splitCsvLine(line));

        if (static_cast<int>(rows.size()) >= max_rows) {
            break;
        }
    }

    table->setColumnCount(static_cast<int>(header.size()));
    table->setRowCount(static_cast<int>(rows.size()));
    QStringList display_header;
    display_header.reserve(header.size());

    for (const auto& column : header) {
        display_header.push_back(axisPresentationForColumn(column.trimmed()).label);
    }

    table->setHorizontalHeaderLabels(display_header);

    for (int r = 0; r < static_cast<int>(rows.size()); ++r) {
        const auto& row = rows[static_cast<std::size_t>(r)];

        for (int c = 0; c < header.size(); ++c) {
            const auto raw_value = c < row.size() ? row[c] : QString{};
            const AxisPresentation axis =
                c < header.size()
                    ? axisPresentationForColumn(header[c].trimmed())
                    : AxisPresentation{};
            QString display_value = raw_value;

            if (axis.scale != 1.0) {
                bool ok = false;
                const double numeric = raw_value.toDouble(&ok);

                if (ok && std::isfinite(numeric)) {
                    display_value = QString::number(numeric * axis.scale, 'g', 8);
                }
            }

            table->setItem(r, c, new QTableWidgetItem(display_value));
        }
    }

    table->resizeColumnsToContents();
}

void MainWindow::plotCsv2D(const QString& path,
                           const QString& x_column,
                           const QString& y_column,
                           const QString& group_column,
                           QGraphicsScene* scene,
                           const QString& title,
                           const bool connect_groups)
{
    scene->clear();
    scene->setBackgroundBrush(QColor(13, 16, 22));

    QFile file(path);
    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
        auto* error_item = scene->addText("Could not open: " + path);
        error_item->setDefaultTextColor(QColor(255, 150, 150));
        error_item->setPos(24, 24);
        return;
    }

    QTextStream stream(&file);

    QStringList header;
    std::vector<PlotPoint> points;
    std::map<int, std::vector<PlotPoint>> grouped_points;
    const AxisPresentation x_axis = axisPresentationForColumn(x_column);
    const AxisPresentation y_axis = axisPresentationForColumn(y_column);

    int x_col = -1;
    int y_col = -1;
    int group_col = -1;

    while (!stream.atEnd()) {
        const auto line = stream.readLine();

        if (line.trimmed().isEmpty() || line.startsWith("#")) {
            continue;
        }

        if (header.isEmpty()) {
            header = splitCsvLine(line);
            x_col = columnIndex(header, x_column);
            y_col = columnIndex(header, y_column);

            if (!group_column.isEmpty()) {
                group_col = columnIndex(header, group_column);
            }

            continue;
        }

        const auto cols = splitCsvLine(line);

        if (x_col < 0 || y_col < 0 ||
            x_col >= cols.size() || y_col >= cols.size()) {
            continue;
        }

        bool ok_x = false;
        bool ok_y = false;

        const double x = cols[x_col].toDouble(&ok_x);
        const double y = cols[y_col].toDouble(&ok_y);

        if (!ok_x || !ok_y) {
            continue;
        }

        PlotPoint point{x * x_axis.scale, y * y_axis.scale};
        points.push_back(point);

        if (group_col >= 0 && group_col < cols.size()) {
            bool ok_group = false;
            const int group = cols[group_col].toInt(&ok_group);

            if (ok_group) {
                grouped_points[group].push_back(point);
            }
        }
    }

    if (points.empty()) {
        auto* error_item = scene->addText("No points found in: " + path);
        error_item->setDefaultTextColor(QColor(255, 220, 150));
        error_item->setPos(24, 24);
        return;
    }

    double min_x = std::numeric_limits<double>::infinity();
    double max_x = -std::numeric_limits<double>::infinity();
    double min_y = std::numeric_limits<double>::infinity();
    double max_y = -std::numeric_limits<double>::infinity();

    for (const auto& point : points) {
        min_x = std::min(min_x, point.x);
        max_x = std::max(max_x, point.x);
        min_y = std::min(min_y, point.y);
        max_y = std::max(max_y, point.y);
    }

    const double width = std::max(1.0e-12, max_x - min_x);
    const double height = std::max(1.0e-12, max_y - min_y);

    constexpr double canvas_w = 950.0;
    constexpr double canvas_h = 650.0;
    constexpr double left = 68.0;
    constexpr double right = 18.0;
    constexpr double top = 50.0;
    constexpr double bottom = 54.0;

    const double plot_w = canvas_w - left - right;
    const double plot_h = canvas_h - top - bottom;
    const double scale_x = plot_w / width;
    const double scale_y = plot_h / height;

    const bool keep_aspect =
        title.contains("Focal", Qt::CaseInsensitive) ||
        title.contains("Envelope", Qt::CaseInsensitive);

    const double sx_scale = keep_aspect ? std::min(scale_x, scale_y) : scale_x;
    const double sy_scale = keep_aspect ? std::min(scale_x, scale_y) : scale_y;
    const double data_w = width * sx_scale;
    const double data_h = height * sy_scale;
    const double data_left = left + 0.5 * (plot_w - data_w);
    const double data_bottom = top + 0.5 * (plot_h - data_h) + data_h;

    const auto mapPoint = [&](const PlotPoint& point) {
        const double sx = data_left + (point.x - min_x) * sx_scale;
        const double sy = data_bottom - (point.y - min_y) * sy_scale;
        return QPointF(sx, sy);
    };

    scene->setSceneRect(0.0, 0.0, canvas_w, canvas_h);
    auto* title_item = scene->addText(QString("%1 | points: %2").arg(title).arg(points.size()));
    title_item->setDefaultTextColor(QColor(232, 238, 248));
    title_item->setScale(1.18);
    title_item->setPos(left, 12.0);

    QPen frame_pen(QColor(92, 108, 135));
    frame_pen.setWidthF(1.0);
    scene->addRect(
        left,
        top,
        plot_w,
        plot_h,
        frame_pen,
        QBrush(QColor(16, 21, 30))
    );

    QPen grid_pen(QColor(45, 55, 74));
    grid_pen.setWidthF(0.75);

    for (int i = 0; i <= 5; ++i) {
        const double gx = left + plot_w * static_cast<double>(i) / 5.0;
        const double gy = top + plot_h * static_cast<double>(i) / 5.0;

        scene->addLine(gx, top, gx, top + plot_h, grid_pen);
        scene->addLine(left, gy, left + plot_w, gy, grid_pen);

        const double x_value = min_x + (max_x - min_x) * static_cast<double>(i) / 5.0;
        const double y_value = max_y - (max_y - min_y) * static_cast<double>(i) / 5.0;

        auto* x_tick = scene->addText(formatPlotTick(x_value));
        x_tick->setDefaultTextColor(QColor(165, 180, 204));
        x_tick->setScale(0.72);
        x_tick->setPos(gx - 28.0, top + plot_h + 8.0);

        auto* y_tick = scene->addText(formatPlotTick(y_value));
        y_tick->setDefaultTextColor(QColor(165, 180, 204));
        y_tick->setScale(0.72);
        y_tick->setPos(14.0, gy - 9.0);
    }

    QPen axes_pen(QColor(120, 135, 160));
    axes_pen.setWidthF(1.1);

    scene->addLine(left, top + plot_h, left + plot_w, top + plot_h, axes_pen);
    scene->addLine(left, top, left, top + plot_h, axes_pen);

    auto* x_label = scene->addText(x_axis.label);
    x_label->setDefaultTextColor(QColor(232, 238, 248));
    x_label->setScale(0.88);
    x_label->setPos(left + plot_w - 170.0, canvas_h - 34.0);

    auto* y_label = scene->addText(y_axis.label);
    y_label->setDefaultTextColor(QColor(232, 238, 248));
    y_label->setScale(0.88);
    y_label->setPos(8.0, top - 28.0);

    if (connect_groups && !grouped_points.empty()) {
        const bool close_groups = title.contains("Envelope", Qt::CaseInsensitive);
        QPen line_pen(
            close_groups
                ? QColor(125, 210, 255, 145)
                : QColor(120, 255, 210, 120)
        );
        line_pen.setWidthF(1.35);

        for (const auto& [group, group_points] : grouped_points) {
            if (group_points.size() < 2) {
                continue;
            }

            QPainterPath path_item;
            path_item.moveTo(mapPoint(group_points.front()));

            for (std::size_t i = 1; i < group_points.size(); ++i) {
                path_item.lineTo(mapPoint(group_points[i]));
            }

            if (close_groups) {
                path_item.lineTo(mapPoint(group_points.front()));
            }

            scene->addPath(path_item, line_pen);
        }
    } else {
        const std::size_t stride =
            points.size() > 50000 ? points.size() / 50000 : 1;

        for (std::size_t i = 0; i < points.size(); i += stride) {
            const auto p = mapPoint(points[i]);
            scene->addEllipse(
                p.x() - 1.7,
                p.y() - 1.7,
                3.2,
                3.2,
                QPen(QColor(185, 235, 255, 190)),
                QBrush(QColor(125, 210, 255, 150))
            );
        }
    }

    const QRectF complete_bounds =
        scene->itemsBoundingRect().adjusted(-20.0, -20.0, 20.0, 20.0);

    if (complete_bounds.isValid() && !complete_bounds.isEmpty()) {
        scene->setSceneRect(complete_bounds);
    }

    QGraphicsView* target_view = nullptr;

    if (scene == trajectory_scene_) {
        target_view = trajectory_view_;
    } else if (scene == focal_slice_scene_) {
        target_view = focal_slice_view_;
    } else if (scene == envelope_scene_) {
        target_view = envelope_view_;
    }

    if (target_view != nullptr) {
        fitSceneInView(target_view, scene);

        QTimer::singleShot(0, target_view, [target_view, scene]() {
            fitSceneInView(target_view, scene);
        });

        QTimer::singleShot(120, target_view, [target_view, scene]() {
            fitSceneInView(target_view, scene);
        });
    }
}


