        ).arg(color.name(QColor::HexRgb))
    );
}

void MainWindow::setLayerColorFromSwatch(QPushButton* swatch,
                                         const int layer_index,
                                         const QColor& initial)
{
    if (swatch == nullptr || combined_scene_viewer_ == nullptr || layer_index < 0) {
        return;
    }

    QColor current = swatch->property("layer_color").value<QColor>();

    if (!current.isValid()) {
        current = initial;
    }

    const QColor color =
        QColorDialog::getColor(current, this, "Layer color", QColorDialog::ShowAlphaChannel);

    if (!color.isValid()) {
        return;
    }

    updateLayerSwatch(swatch, color);
    combined_scene_viewer_->setLayerColor(layer_index, color);
}

