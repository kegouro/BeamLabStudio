void MainWindow::dragEnterEvent(QDragEnterEvent* event)
{
    if (event == nullptr || event->mimeData() == nullptr) {
        return;
    }

    const QList<QUrl> urls = event->mimeData()->urls();

    if (urls.isEmpty() || !urls.first().isLocalFile()) {
        event->ignore();
        return;
    }

    const QString suffix =
        QFileInfo(urls.first().toLocalFile()).suffix().toLower();

    if (suffix == "root" || suffix == "csv" || suffix == "txt" || suffix == "dat") {
        event->acceptProposedAction();
        return;
    }

    event->ignore();
}

void MainWindow::dropEvent(QDropEvent* event)
{
    if (event == nullptr || event->mimeData() == nullptr) {
        return;
    }

    const QList<QUrl> urls = event->mimeData()->urls();

    if (urls.isEmpty() || !urls.first().isLocalFile()) {
        event->ignore();
        return;
    }

    openDataFileAndRunWithPath(urls.first().toLocalFile());
    event->acceptProposedAction();
}

void MainWindow::loadManifest(const QString& path)
{
    const auto text = readTextFile(path);

    if (text.isEmpty()) {
        QMessageBox::warning(this, "BeamLabStudio", "Could not read manifest.");
        return;
    }

    current_manifest_path_ = path;
    QFileInfo manifest_info(path);
    QDir run_dir = manifest_info.dir();
    run_dir.cdUp();
    current_run_dir_ = run_dir.absolutePath();

    const auto trajectories_csv = resolvePath(
        extractJsonString(text, "trajectories_preview_csv"),
        path
    );

    const auto focal_slice_csv = resolvePath(
        extractJsonString(text, "focal_slice_points_csv"),
        path
    );

    const auto envelope_csv = resolvePath(
        extractJsonString(text, "envelope_rings_csv"),
        path
    );

    const auto trajectories_obj = resolvePath(
        extractJsonString(text, "trajectories_preview_obj"),
        path
    );

    const auto caustic_obj = resolvePath(
        extractJsonString(text, "beam_caustic_preview_obj"),
        path
    );

    QString lens_obj_raw = extractJsonString(text, "effective_lens_body_preview_obj");

    if (lens_obj_raw.isEmpty()) {
        lens_obj_raw = extractJsonString(text, "effective_lens_disk_preview_obj");
    }

    const auto lens_obj = resolvePath(
        lens_obj_raw,
        path
    );

    QString full_envelope_obj_raw =
        extractJsonString(text, "full_beam_envelope_preview_obj");

    if (full_envelope_obj_raw.isEmpty()) {
        full_envelope_obj_raw = extractJsonString(text, "full_beam_envelope_obj");
    }

    const auto full_envelope_obj = resolvePath(
        full_envelope_obj_raw,
        path
    );

    current_trajectories_csv_ = trajectories_csv;
    current_focal_slice_csv_ = focal_slice_csv;
    current_envelope_csv_ = envelope_csv;
    current_trajectories_obj_ = trajectories_obj;
    current_caustic_obj_ = caustic_obj;
    current_lens_obj_ = lens_obj;
    current_full_envelope_obj_ = full_envelope_obj;
    current_beamline_obj_.clear();
    updateExportControls();

    dashboard_->loadFromManifest(
        text,
        trajectories_csv,
        focal_slice_csv,
        envelope_csv,
        caustic_obj,
        lens_obj
    );

    if (statistics_dashboard_ != nullptr) {
        statistics_dashboard_->loadRunFromManifest(path);
    }
    status_label_->setText("Loaded: " + path);

    trajectories_obj_viewer_->loadObj(trajectories_obj);
    caustic_obj_viewer_->loadObj(caustic_obj);
    lens_obj_viewer_->loadObj(lens_obj);

    combined_scene_viewer_->clearLayers();

    combined_trajectory_layer_ = combined_scene_viewer_->addObjLayer(
        "Trajectories",
        trajectories_obj,
        QColor(120, 255, 210)
    );

    combined_caustic_layer_ = combined_scene_viewer_->addObjLayer(
        "Focal envelope proxy",
        caustic_obj,
        QColor(118, 170, 255)
    );

    combined_lens_layer_ = combined_scene_viewer_->addObjLayer(
        "Effective lens body",
        lens_obj,
        QColor(255, 190, 120)
    );

    combined_full_envelope_layer_ = combined_scene_viewer_->addObjLayer(
        "Full beam envelope",
        full_envelope_obj,
        QColor(180, 140, 255)
    );

    combined_beamline_layer_ = -1;

    updateLayerSwatch(trajectory_color_swatch_, QColor(120, 255, 210));
    updateLayerSwatch(caustic_color_swatch_, QColor(118, 170, 255));
    updateLayerSwatch(lens_color_swatch_, QColor(255, 190, 120));
    updateLayerSwatch(full_envelope_color_swatch_, QColor(180, 140, 255));
    updateLayerSwatch(beamline_color_swatch_, QColor(205, 214, 226));

    combined_scene_viewer_->setLayerOpacity(combined_trajectory_layer_, 0.55);
    combined_scene_viewer_->setLayerOpacity(combined_caustic_layer_, 0.35);
    combined_scene_viewer_->setLayerOpacity(combined_lens_layer_, 0.95);
    combined_scene_viewer_->setLayerOpacity(combined_full_envelope_layer_, 0.25);

    combined_scene_viewer_->setLayerLineWidth(combined_trajectory_layer_, 0.8);
    combined_scene_viewer_->setLayerLineWidth(combined_caustic_layer_, 1.1);
    combined_scene_viewer_->setLayerLineWidth(combined_lens_layer_, 1.1);
    combined_scene_viewer_->setLayerLineWidth(combined_full_envelope_layer_, 0.9);

    {
        const QSignalBlocker b1(combined_trajectories_check_);
        const QSignalBlocker b2(combined_caustic_check_);
        const QSignalBlocker b3(combined_lens_check_);
        const QSignalBlocker b4(combined_full_envelope_check_);
        const QSignalBlocker b5(combined_beamline_check_);

        combined_trajectories_check_->setEnabled(combined_trajectory_layer_ >= 0);
        combined_caustic_check_->setEnabled(combined_caustic_layer_ >= 0);
        combined_lens_check_->setEnabled(combined_lens_layer_ >= 0);
        combined_full_envelope_check_->setEnabled(combined_full_envelope_layer_ >= 0);
        combined_beamline_check_->setEnabled(false);

        combined_trajectories_check_->setChecked(false);
        combined_caustic_check_->setChecked(combined_caustic_layer_ >= 0);
        combined_lens_check_->setChecked(combined_lens_layer_ >= 0);
        combined_full_envelope_check_->setChecked(false);
        combined_beamline_check_->setChecked(false);
    }

    if (build_full_envelope_button_ != nullptr) {
        build_full_envelope_button_->setEnabled(QFileInfo::exists(trajectories_csv));
    }

    if (clear_beamline_button_ != nullptr) {
        clear_beamline_button_->setEnabled(false);
    }

    const int trajectory_count =
        combined_scene_viewer_->layerPolylineCount(combined_trajectory_layer_);

    const bool has_trajectory_control = trajectory_count > 0;

    trajectory_count_slider_->setEnabled(has_trajectory_control);
    trajectory_count_spin_->setEnabled(has_trajectory_control);

    if (has_trajectory_control) {
        const int default_visible = trajectory_count / 2;
        trajectory_count_label_->setText(
            QString("Visible trajectories (0-%1)").arg(trajectory_count)
        );

        const QSignalBlocker b1(trajectory_count_slider_);
        const QSignalBlocker b2(trajectory_count_spin_);

        trajectory_count_slider_->setRange(0, trajectory_count);
        trajectory_count_spin_->setRange(0, trajectory_count);

        trajectory_count_slider_->setValue(default_visible);
        trajectory_count_spin_->setValue(default_visible);

        combined_scene_viewer_->setLayerMaxPolylines(
            combined_trajectory_layer_,
            default_visible
        );
    } else {
        trajectory_count_label_->setText("Visible trajectories (0)");
    }

    {
        const QSignalBlocker blocker(trajectory_parameter_slider_);
        trajectory_parameter_slider_->setValue(100);
    }

    trajectory_parameter_value_label_->setText("1.00");
    combined_scene_viewer_->setTrajectoryParameter(1.0);
    updateCombinedDisplayMode();
    combined_scene_viewer_->resetCamera();

    loadTablePreview(trajectories_csv, trajectories_table_, 500);
    loadTablePreview(focal_slice_csv, focal_slice_table_, 500);
    loadTablePreview(envelope_csv, envelope_table_, 500);

    plotCsv2D(
        trajectories_csv,
        "z_m",
        "x_m",
        "trajectory_index",
        trajectory_scene_,
        "Individual trajectories: z vs x",
        true
    );

    plotCsv2D(
        focal_slice_csv,
        "u_m",
        "v_m",
        "",
        focal_slice_scene_,
        "Focal slice preview: u vs v",
        false
    );

    plotCsv2D(
        envelope_csv,
        "u_m",
        "v_m",
        "slice_index",
        envelope_scene_,
        "Focal envelope proxy: u vs v",
        true
    );

    showWorkspace();
    tabs_->setCurrentIndex(1);
    addToRecentRuns(path);
}

void MainWindow::updateCombinedDisplayMode()
{
    if (combined_scene_viewer_ == nullptr || beam_display_mode_ == nullptr) {
        return;
    }

    const bool has_trajectories = combined_trajectory_layer_ >= 0;
    const bool has_caustic = combined_caustic_layer_ >= 0;
    const bool has_lens = combined_lens_layer_ >= 0;
    const bool has_full_envelope = combined_full_envelope_layer_ >= 0;
    const bool has_beamline = combined_beamline_layer_ >= 0;

    const int mode = beam_display_mode_->currentIndex();
    const bool wants_trajectories = mode == 0 || mode == 2;
    const bool wants_caustic = mode == 1 || mode == 2;
    const bool wants_full_envelope = mode == 2;
    const bool wants_beamline = mode == 2;
    const bool wants_lens = true;

    const bool show_trajectories = wants_trajectories && has_trajectories;
    const bool show_caustic = wants_caustic && has_caustic;
    const bool show_lens = wants_lens && has_lens;
    const bool show_full_envelope = wants_full_envelope && has_full_envelope;
    const bool show_beamline = wants_beamline && has_beamline;

    {
        const QSignalBlocker b1(combined_trajectories_check_);
        const QSignalBlocker b2(combined_caustic_check_);
        const QSignalBlocker b3(combined_lens_check_);
        const QSignalBlocker b4(combined_full_envelope_check_);
        const QSignalBlocker b5(combined_beamline_check_);

        combined_trajectories_check_->setEnabled(has_trajectories);
        combined_caustic_check_->setEnabled(has_caustic);
        combined_lens_check_->setEnabled(has_lens);
        combined_full_envelope_check_->setEnabled(has_full_envelope);
        combined_beamline_check_->setEnabled(has_beamline);

        combined_trajectories_check_->setChecked(show_trajectories);
        combined_caustic_check_->setChecked(show_caustic);
        combined_lens_check_->setChecked(show_lens);
        combined_full_envelope_check_->setChecked(show_full_envelope);
        combined_beamline_check_->setChecked(show_beamline);
    }

    combined_scene_viewer_->setLayerVisible(combined_trajectory_layer_, show_trajectories);
    combined_scene_viewer_->setLayerVisible(combined_caustic_layer_, show_caustic);
    combined_scene_viewer_->setLayerVisible(combined_lens_layer_, show_lens);
    combined_scene_viewer_->setLayerVisible(combined_full_envelope_layer_, show_full_envelope);
    combined_scene_viewer_->setLayerVisible(combined_beamline_layer_, show_beamline);

    const bool has_trajectory_controls =
        show_trajectories &&
        combined_scene_viewer_->layerPolylineCount(combined_trajectory_layer_) > 0;

    trajectory_count_label_->setVisible(has_trajectory_controls);
    trajectory_count_slider_->setVisible(has_trajectory_controls);
    trajectory_count_spin_->setVisible(has_trajectory_controls);
    trajectory_parameter_label_->setVisible(has_trajectory_controls);
    trajectory_parameter_value_label_->setVisible(has_trajectory_controls);
    trajectory_parameter_slider_->setVisible(has_trajectory_controls);

    trajectory_count_slider_->setEnabled(has_trajectory_controls);
    trajectory_count_spin_->setEnabled(has_trajectory_controls);
    trajectory_parameter_slider_->setEnabled(has_trajectory_controls);

    trajectory_color_swatch_->setEnabled(has_trajectories);
    caustic_color_swatch_->setEnabled(has_caustic);
    lens_color_swatch_->setEnabled(has_lens);
    full_envelope_color_swatch_->setEnabled(has_full_envelope);
    beamline_color_swatch_->setEnabled(has_beamline);
}

